generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                String             @id @default(uuid())
  name              String
  email             String             @unique
  password          String
  avatar            String?
  phone             String?
  role              Role               @default(GUEST)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  isEmailVerified   Boolean            @default(false)
  bookings          Booking[]
  conversations1    Conversation[]     @relation("Participant1")
  conversations2    Conversation[]     @relation("Participant2")
  hostVerifications HostVerification[]
  messages          Message[]
  payments          Payment[]
  properties        Property[]
  reviews           Review[]
  wishlists         Wishlist[]
}

model VerificationToken {
  id        String   @id @default(uuid())
  email     String
  token     String   @unique
  type      String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Property {
  id                 String              @id @default(uuid())
  title              String
  description        String
  location           String
  country            String
  address            String?
  latitude           Float?
  longitude          Float?
  images             String[]
  isPublished        Boolean             @default(false)
  hostId             String
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  reviewNote         String?
  verificationStatus VerificationStatus?
  conversations      Conversation[]
  host               User                @relation(fields: [hostId], references: [id])
  reviews            Review[]
  rooms              Room[]
  wishlists          Wishlist[]
}

model Room {
  id            String    @id @default(uuid())
  propertyId    String
  name          String
  type          RoomType  @default(STANDARD)
  description   String?
  pricePerNight Int
  cleaningFee   Int       @default(0)
  serviceFee    Int       @default(0)
  guests        Int
  bedrooms      Int
  beds          Int
  bathrooms     Int
  images        String[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  bookings      Booking[]
  property      Property  @relation(fields: [propertyId], references: [id])
}

model Booking {
  id          String        @id @default(uuid())
  userId      String
  checkIn     DateTime
  checkOut    DateTime
  nights      Int
  guestsCount Int
  totalPrice  Int
  status      BookingStatus @default(PENDING)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  roomId      String
  room        Room          @relation(fields: [roomId], references: [id])
  user        User          @relation(fields: [userId], references: [id])
  payment     Payment?
}

model Review {
  id         String   @id @default(uuid())
  userId     String
  propertyId String
  rating     Int
  comment    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  images     String[] @default([])
  property   Property @relation(fields: [propertyId], references: [id])
  user       User     @relation(fields: [userId], references: [id])

  @@unique([userId, propertyId])
}

model Wishlist {
  id         String   @id @default(uuid())
  userId     String
  propertyId String
  createdAt  DateTime @default(now())
  property   Property @relation(fields: [propertyId], references: [id])
  user       User     @relation(fields: [userId], references: [id])

  @@unique([userId, propertyId])
}

model Conversation {
  id             String    @id @default(uuid())
  participant1Id String
  participant2Id String
  lastMessageAt  DateTime  @default(now())
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  propertyId     String?
  participant1   User      @relation("Participant1", fields: [participant1Id], references: [id])
  participant2   User      @relation("Participant2", fields: [participant2Id], references: [id])
  property       Property? @relation(fields: [propertyId], references: [id])
  messages       Message[]

  @@unique([participant1Id, participant2Id, propertyId])
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  senderId       String
  content        String
  isRead         Boolean      @default(false)
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  sender         User         @relation(fields: [senderId], references: [id])
}

model Payment {
  id            String        @id @default(uuid())
  userId        String
  bookingId     String        @unique
  amount        Int
  currency      String        @default("usd")
  status        PaymentStatus @default(PENDING)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  provider      String?
  transactionId String?       @unique
  booking       Booking       @relation(fields: [bookingId], references: [id])
  user          User          @relation(fields: [userId], references: [id])
}

model HostVerification {
  id                  String             @id @default(uuid())
  userId              String
  verificationType    VerificationType
  fullName            String?
  cccdNumber          String?
  cccdFrontImage      String?
  cccdBackImage       String?
  selfieImage         String?
  companyName         String?
  businessLicense     String?
  taxCode             String?
  legalRepresentative String?
  representativeCCCD  String?
  status              VerificationStatus @default(PENDING)
  reviewNote          String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  user                User               @relation(fields: [userId], references: [id])
}

enum Role {
  GUEST
  HOST
  ADMIN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum VerificationType {
  PERSONAL
  BUSINESS
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum RoomType {
  STANDARD
  VIP
  DELUXE
  SUITE
}
